<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="College store (demo)"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/afeka_green" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Prototype checkout — amounts deduct from your synced balance."
            android:textColor="#666666" />

        <Button
            android:id="@+id/btnBuyNotebook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Notebook — 5.00 AFK"
            android:backgroundTint="#FF5252" />

        <Button
            android:id="@+id/btnBuyCoffee"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Coffee voucher — 3.00 AFK"
            android:backgroundTint="#FF5252" />

        <Button
            android:id="@+id/btnBuyHoodie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Afeka hoodie — 25.00 AFK"
            android:backgroundTint="#FF5252" />

        <Button
            android:id="@+id/btnPayBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Back" />

    </LinearLayout>
</ScrollView>
