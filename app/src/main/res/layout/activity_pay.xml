<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:scrollbars="vertical"
    android:fadeScrollbars="false"
    android:scrollbarSize="3dp"
    android:scrollbarThumbVertical="@android:color/darker_gray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="College Store"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Spend your campus coins on Afeka items"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <!-- Balance banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_earn_card"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Your balance"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvPayBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="..."
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Section: Everyday -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EVERYDAY"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textColor="@color/accent_green"
            android:layout_marginBottom="10dp" />

        <!-- Print Credit -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_earn_card"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Print Credit"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Up to 20 pages at any campus printer"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBuyPrint"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="50 AFK"
                android:textSize="13sp"
                android:backgroundTint="@color/accent_green"
                android:textColor="@color/bg_primary"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <!-- Coffee Voucher -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_earn_card"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Coffee Voucher"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Redeemable at campus cafe"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBuyCoffee"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="100 AFK"
                android:textSize="13sp"
                android:backgroundTint="@color/accent_green"
                android:textColor="@color/bg_primary"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <!-- Campus Lunch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_earn_card"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="22dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Campus Lunch"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Meal voucher for the campus cafeteria"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBuyLunch"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="200 AFK"
                android:textSize="13sp"
                android:backgroundTint="@color/accent_green"
                android:textColor="@color/bg_primary"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <!-- Section: Campus Gear -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CAMPUS GEAR"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textColor="@color/accent_blue"
            android:layout_marginBottom="10dp" />

        <!-- USB Flash Drive -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_earn_card"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USB Flash Drive"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="16 GB drive from the campus store"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBuyUsb"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="800 AFK"
                android:textSize="13sp"
                android:backgroundTint="@color/accent_blue"
                android:textColor="@color/white"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <!-- Notebook -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_earn_card"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="22dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notebook"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ruled A5 notebook from campus store"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBuyNotebook"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="1,300 AFK"
                android:textSize="13sp"
                android:backgroundTint="@color/accent_blue"
                android:textColor="@color/white"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <!-- Section: Merchandise -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MERCHANDISE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textColor="@color/accent_red"
            android:layout_marginBottom="10dp" />

        <!-- Afeka T-Shirt -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_earn_card"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Afeka T-Shirt"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Official Afeka College T-shirt"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBuyTshirt"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="2,500 AFK"
                android:textSize="13sp"
                android:backgroundTint="@color/accent_red"
                android:textColor="@color/white"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <!-- Afeka Hoodie -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_earn_card"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Afeka Hoodie"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Premium campus merchandise"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBuyHoodie"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="5,000 AFK"
                android:textSize="13sp"
                android:backgroundTint="@color/accent_red"
                android:textColor="@color/white"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <!-- Section: More Deals -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MORE DEALS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textColor="#FFB800"
            android:layout_marginBottom="10dp" />

        <!-- Daily Parking Pass -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_earn_card"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Parking Pass"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="One full day at campus parking lot"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBuyParkingPass"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="350 AFK"
                android:textSize="13sp"
                android:backgroundTint="#FFB800"
                android:textColor="@color/bg_primary"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <!-- Lab Kit Refill -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_earn_card"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lab Kit Refill"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Consumables bundle for workshops"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBuyLabKit"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="650 AFK"
                android:textSize="13sp"
                android:backgroundTint="#FFB800"
                android:textColor="@color/bg_primary"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <!-- Power Bank -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_earn_card"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Power Bank"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10,000 mAh emergency charger"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBuyPowerBank"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="1,800 AFK"
                android:textSize="13sp"
                android:backgroundTint="#FFB800"
                android:textColor="@color/bg_primary"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <!-- Wireless Mouse -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_earn_card"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wireless Mouse"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bluetooth mouse from campus gear shop"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBuyMouse"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="2,200 AFK"
                android:textSize="13sp"
                android:backgroundTint="#FFB800"
                android:textColor="@color/bg_primary"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnPayBack"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Back"
            android:backgroundTint="@color/bg_card"
            android:textColor="@color/text_secondary"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>
