<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/bg_primary">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GAME OVER"
        android:textSize="34sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textColor="@color/accent_red" />

    <View
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:background="@color/accent_red"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvFinalScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You got 6 questions right!"
        android:textSize="20sp"
        android:textColor="@color/text_primary" />

    <TextView
        android:id="@+id/tvNewBalance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Balance: 36.00 AFK"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/accent_green"
        android:layout_marginTop="20dp" />

    <Button
        android:id="@+id/btnPlayAgain"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="PLAY AGAIN"
        android:textStyle="bold"
        android:layout_marginTop="40dp"
        android:backgroundTint="@color/accent_green"
        android:textColor="@color/bg_primary"
        app:cornerRadius="14dp" />

    <Button
        android:id="@+id/btnBackToEarn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="BACK TO EARN"
        android:backgroundTint="@color/bg_card"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="10dp"
        app:cornerRadius="14dp" />

    <Button
        android:id="@+id/btnGoHome"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="MAIN MENU"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/accent_blue"
        android:textColor="@color/white"
        app:cornerRadius="14dp" />

</LinearLayout>
