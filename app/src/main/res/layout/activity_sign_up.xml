<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="32dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join the Afeka campus coin network"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="36dp" />

        <!-- Username -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="USERNAME"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="e.g. yosi_cohen"
            android:inputType="textNoSuggestions"
            android:padding="14dp"
            android:background="@drawable/bg_input_dark"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Others use this name to send you coins. Letters, numbers and _ only."
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <!-- Email -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AFEKA EMAIL"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etSignUpEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="you@afeka.ac.il"
            android:inputType="textEmailAddress"
            android:padding="14dp"
            android:background="@drawable/bg_input_dark"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="15sp" />

        <!-- Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PASSWORD"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etSignUpPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="at least 6 characters"
            android:inputType="textPassword"
            android:padding="14dp"
            android:background="@drawable/bg_input_dark"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="15sp" />

        <!-- Confirm Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONFIRM PASSWORD"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etSignUpConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="repeat your password"
            android:inputType="textPassword"
            android:padding="14dp"
            android:background="@drawable/bg_input_dark"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnCreateAccount"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="CREATE ACCOUNT"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:backgroundTint="@color/accent_green"
            android:textColor="@color/bg_primary"
            android:layout_marginTop="28dp"
            app:cornerRadius="12dp" />

        <Button
            android:id="@+id/btnBackToLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Already have an account? Log in"
            android:textSize="13sp"
            android:backgroundTint="@color/bg_card"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="12dp"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>
