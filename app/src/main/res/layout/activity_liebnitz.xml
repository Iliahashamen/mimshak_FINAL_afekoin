<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <com.example.mimshak_final_afekoin.LiebnitzGameView
        android:id="@+id/liebnitzGameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Retro pixel HUD overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="14dp"
        android:background="#DD000000">

        <!-- Score + Exit row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvLiebnitzScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SCORE: 0"
                android:textColor="#00FF41"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvLiebnitzLives"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="LIVES: 3"
                android:textColor="#FFB800"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <Button
                android:id="@+id/btnLiebnitzExit"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="EXIT"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:backgroundTint="#1A1A1A"
                android:textColor="#00FF41"
                app:strokeColor="#00FF41"
                app:strokeWidth="1dp"
                app:cornerRadius="4dp" />
        </LinearLayout>

        <!-- Equation display — big retro green text -->
        <TextView
            android:id="@+id/tvEquation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GET READY"
            android:textColor="#00FF41"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center"
            android:letterSpacing="0.08" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&lt; TAP TO STEER  |  FLY INTO THE ANSWER &gt;"
            android:textColor="#33FF33"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:letterSpacing="0.06" />
    </LinearLayout>

</FrameLayout>
