<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="#F8F9FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Afekliker"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/afeka_green" />

    <TextView
        android:id="@+id/tvAfeklikerTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="0:20"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/tvAfeklikerTaps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Taps: 0"
        android:textSize="18sp" />

    <ImageButton
        android:id="@+id/btnAfekoinLogo"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="32dp"
        android:background="@android:color/transparent"
        android:contentDescription="Tap to earn"
        android:scaleType="centerCrop"
        android:src="@mipmap/afekoin_logo" />

    <Button
        android:id="@+id/btnAfeklikerDone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Finish and claim"
        android:backgroundTint="@color/afeka_green" />

</LinearLayout>
