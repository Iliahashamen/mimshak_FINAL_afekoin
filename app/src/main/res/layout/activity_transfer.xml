<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="P2P Transfer"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Send coins directly to another student"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_earn_card"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECIPIENT"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etTransferUsername"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="username (before @ in Afeka email)"
                android:inputType="text"
                android:padding="14dp"
                android:background="@drawable/bg_input_dark"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AMOUNT (AFK)"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etTransferAmount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:padding="14dp"
                android:background="@drawable/bg_input_dark"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnSendTransfer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="SEND AFEKOINS"
                android:textStyle="bold"
                android:backgroundTint="@color/accent_purple"
                android:textColor="@color/white"
                android:layout_marginTop="24dp"
                app:cornerRadius="12dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnTransferBack"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Back"
            android:backgroundTint="@color/bg_card"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="12dp"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>
