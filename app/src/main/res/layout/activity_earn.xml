<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Earn Afekoins"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Play games to earn campus coins"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp" />

        <!-- Class check card -->
        <LinearLayout
            android:id="@+id/layoutQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_earn_card"
            android:padding="28dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎓  Are you in class right now?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Games are locked during the first 45 min of class to help you focus."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnYesInClass"
                android:layout_width="220dp"
                android:layout_height="48dp"
                android:text="YES, I'M IN CLASS"
                android:textSize="13sp"
                android:backgroundTint="@color/accent_green"
                android:textColor="@color/bg_primary"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"
                app:cornerRadius="12dp" />

            <Button
                android:id="@+id/btnNoNotInClass"
                android:layout_width="220dp"
                android:layout_height="48dp"
                android:text="NO, I'M FREE"
                android:textSize="13sp"
                android:backgroundTint="@color/bg_card"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp" />

        </LinearLayout>

        <!-- Games list (hidden until class check) -->
        <LinearLayout
            android:id="@+id/layoutEarnButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Afequiz card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_earn_card"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:text="📝"
                        android:textSize="26sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Afequiz"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CS &amp; Android trivia — 1 AFK per correct answer"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1 AFK / question"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent_green"
                            android:layout_marginBottom="6dp" />

                        <Button
                            android:id="@+id/btnAfequiz"
                            android:layout_width="72dp"
                            android:layout_height="36dp"
                            android:text="PLAY"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:backgroundTint="@color/accent_green"
                            android:textColor="@color/bg_primary"
                            app:cornerRadius="10dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Afekliker card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_earn_card"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:text="👆"
                        android:textSize="26sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Afekliker"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap the logo as fast as you can — 10 sec"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="up to 2 AFK"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent_blue"
                            android:layout_marginBottom="6dp" />

                        <Button
                            android:id="@+id/btnAfekliker"
                            android:layout_width="72dp"
                            android:layout_height="36dp"
                            android:text="PLAY"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:backgroundTint="@color/accent_blue"
                            android:textColor="@color/white"
                            app:cornerRadius="10dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Liebnitz card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_earn_card"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:text="🚀"
                        android:textSize="26sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Liebnitz"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Spaceship math runner — dodge wrong answers"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="up to 5 AFK"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent_purple"
                            android:layout_marginBottom="6dp" />

                        <Button
                            android:id="@+id/btnLiebnitz"
                            android:layout_width="72dp"
                            android:layout_height="36dp"
                            android:text="PLAY"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:backgroundTint="@color/accent_purple"
                            android:textColor="@color/white"
                            app:cornerRadius="10dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvLockMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_red"
                android:textSize="13sp"
                android:textStyle="bold|italic"
                android:gravity="center"
                android:padding="12dp"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
